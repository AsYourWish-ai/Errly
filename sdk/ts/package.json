{
  "name": "@errly/sdk",
  "version": "1.0.0",
  "description": "Lightweight self-hosted error monitoring SDK for Next.js / TypeScript",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts",
      "default": "./index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": ["index.ts"],
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["errly", "error-monitoring", "nextjs", "observability"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}
